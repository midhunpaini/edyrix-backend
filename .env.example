# App
APP_NAME=Edyrix
APP_ENV=development
SECRET_KEY=change-me-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=1440       # 24 hours
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# Database
POSTGRES_SERVER=postgres
POSTGRES_PORT=5432
POSTGRES_DB=edurix
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_ASYNC_PREFIX=postgresql+asyncpg://
POSTGRES_SYNC_PREFIX=postgresql://

# Redis
REDIS_URL=redis://redis:6379/0

# Firebase (from service account JSON)
FIREBASE_PROJECT_ID=edyrix-xxxxx
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@edyrix-xxxxx.iam.gserviceaccount.com

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx

# Cloudflare R2
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxx
R2_BUCKET_NAME=edyrix-assets
R2_PUBLIC_URL=https://assets.edyrix.in

# Resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@edyrix.in
